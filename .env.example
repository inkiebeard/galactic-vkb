# Infrastructure
DATABASE_URL=postgres://vkb:vkb@localhost:5433/vkb
RAWSTORE_ADAPTER=filesystem
RAWSTORE_PATH=./rawstore
# RAWSTORE_S3_BUCKET=my-bucket
# RAWSTORE_S3_ENDPOINT=http://localhost:9000

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768
LLM_MODEL=llama3.2

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Sectioning
SECTION_STRATEGY=similarity_valley
SECTION_SPLIT_THRESHOLD=0.65
SECTION_WINDOW_SIZE=5
SECTION_MAX_SIZE=8

# Relations
RELATION_THRESHOLD=0.75
RELATION_TOP_K=10
RELATION_CONFIDENCE_STEP=0.05
RELATION_TTL_DAYS=30
RELATION_PRUNE_THRESHOLD=0.6
LLM_RELATION_EXTRACTION=true
LLM_EXTRACT_CANDIDATES=20

# Vector index
IVFFLAT_THRESHOLD=1000
IVFFLAT_LISTS=100

# Workers
WORKER_CONCURRENCY=2
INGEST_MAX_RETRIES=3
RETUNE_INTERVAL_HOURS=6
RETUNE_SUMMARISE=false
JOB_TTL_DAYS=7

# Prompts (optional overrides)
# SUMMARY_PROMPT_FILE=./prompts/entity.txt
# CHUNK_SUMMARY_PROMPT_FILE=./prompts/chunk.txt
# SECTION_SUMMARY_PROMPT_FILE=./prompts/section.txt
# RELATION_EXTRACT_PROMPT_FILE=./prompts/relation.txt

# Servers
MCP_PORT=3333
OBS_PORT=4242
# OBS_SECRET=changeme

# TLS — set both to enable HTTPS on all servers (generate with scripts/gen-cert.ps1)
# TLS_CERT=./certs/cert.pem
# TLS_KEY=./certs/key.pem
